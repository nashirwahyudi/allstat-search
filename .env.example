# GEMINI_API_KEY: Required for real Gemini AI API calls in the AI Stats Assistant.
# Without it, the assistant falls back to canned demo responses.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The base URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"
